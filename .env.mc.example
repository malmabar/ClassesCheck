# Morning Classes Check - isolated PostgreSQL environment
# Copy to .env.mc and adjust passwords/host as needed.

APP_ENV=development

# Isolated DB identity for this project only
MC_DB_HOST=127.0.0.1
MC_DB_PORT=5432
MC_DB_NAME=morning_classes_check
MC_DB_USER=mc_app
MC_DB_PASSWORD=change_me_with_a_strong_password
MC_DB_SSLMODE=disable

# Keep this project in its own schema set
MC_DB_SCHEMA=mc_core
MC_META_SCHEMA=mc_meta

# Runtime connection URL (app)
DATABASE_URL=postgresql+psycopg://mc_app:change_me_with_a_strong_password@127.0.0.1:5432/morning_classes_check?options=-csearch_path%3Dmc_core

# Migration connection URL (can match DATABASE_URL)
ALEMBIC_DATABASE_URL=postgresql+psycopg://mc_app:change_me_with_a_strong_password@127.0.0.1:5432/morning_classes_check?options=-csearch_path%3Dmc_core

# Prevent migration history collisions with other projects
ALEMBIC_VERSION_TABLE=alembic_version_mc
ALEMBIC_VERSION_SCHEMA=mc_meta

# Optional pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
